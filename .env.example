# === Telegram Bot Credentials ===
# Create a bot via @BotFather on Telegram, then paste the token below
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Get your chat ID via @userinfobot on Telegram
TELEGRAM_CHAT_ID=your_chat_id_here

# === MT5 Account ===
# MT5 account login ID (used for account-change detection, not for login)
# MT5_ACCOUNT_ID=your_account_id
